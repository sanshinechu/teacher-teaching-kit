rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isClassOwner(classId) {
      return request.auth != null
        && exists(/databases/$(database)/documents/projectWallClasses/$(classId))
        && get(/databases/$(database)/documents/projectWallClasses/$(classId)).data.ownerUid == request.auth.uid;
    }

    function isTeacher() {
      return request.auth != null
        && request.auth.token.email == 'shine@tmail.ilc.edu.tw';
    }

    function isDashboardModule(moduleId) {
      return moduleId in [
        'profile',
        'picker',
        'links',
        'prompt',
        'flowchart',
        'gallery',
        'music',
        'timer',
        'quotes',
        'mood'
      ];
    }

    function isValidDashboardCounter(moduleId) {
      return isDashboardModule(moduleId)
        && request.resource.data.keys().hasOnly([
          'moduleId',
          'title',
          'href',
          'count',
          'updatedAt'
        ])
        && request.resource.data.moduleId == moduleId
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 80
        && request.resource.data.href is string
        && request.resource.data.href.size() > 0
        && request.resource.data.href.size() <= 200
        && request.resource.data.count is int
        && request.resource.data.count > 0
        && request.resource.data.updatedAt == request.time;
    }

    function isValidMusicMvWork() {
      return request.resource.data.keys().hasOnly([
          'title',
          'category',
          'description',
          'tools',
          'classroom',
          'videoUrl',
          'workUrl',
          'thumbnailUrl',
          'color',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() <= 80
        && request.resource.data.category in ['校園活動', '課程創作', '節慶主題']
        && request.resource.data.description is string
        && request.resource.data.description.size() > 0
        && request.resource.data.description.size() <= 500
        && request.resource.data.tools is list
        && request.resource.data.tools.size() <= 10
        && request.resource.data.classroom is string
        && request.resource.data.classroom.size() <= 300
        && request.resource.data.videoUrl is string
        && request.resource.data.videoUrl.size() <= 500
        && (request.resource.data.videoUrl == '' || request.resource.data.videoUrl.matches('https?://.*'))
        && request.resource.data.workUrl is string
        && request.resource.data.workUrl.size() <= 500
        && (request.resource.data.workUrl == '' || request.resource.data.workUrl.matches('https?://.*'))
        && request.resource.data.thumbnailUrl is string
        && request.resource.data.thumbnailUrl.size() <= 500
        && (request.resource.data.thumbnailUrl == '' || request.resource.data.thumbnailUrl.matches('https?://.*'))
        && request.resource.data.color is string
        && request.resource.data.color.matches('#[0-9a-fA-F]{6}');
    }

    match /dashboardModuleCounters/{moduleId} {
      allow read: if true;
      allow create: if isValidDashboardCounter(moduleId)
        && request.resource.data.count == 1;
      allow update: if isValidDashboardCounter(moduleId)
        && request.resource.data.count == resource.data.count + 1;
      allow delete: if false;
    }

    match /aiMusicMvWorks/{workId} {
      allow read: if true;
      allow create, update: if isTeacher() && isValidMusicMvWork();
      allow delete: if isTeacher();
    }

    match /projectWallClasses/{classId} {
      allow read: if request.auth != null;
      allow create: if isTeacher()
        && request.resource.data.ownerUid == request.auth.uid
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 80;
      allow update, delete: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;

      match /submissions/{submissionId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && exists(/databases/$(database)/documents/projectWallClasses/$(classId))
          && request.resource.data.classId == classId
          && request.resource.data.authorUid == request.auth.uid
          && request.resource.data.title is string
          && request.resource.data.title.size() > 0
          && request.resource.data.title.size() <= 100
          && request.resource.data.url is string
          && request.resource.data.url.matches('https?://.*')
          && request.resource.data.note is string
          && request.resource.data.note.size() <= 1000;
        allow update: if false;
        allow delete: if isClassOwner(classId);
      }
    }
  }
}
