{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "auth": {
    "providers": {
      "googleSignIn": {
        "oAuthBrandDisplayName": "班級作品牆",
        "supportEmail": "shine@tmail.ilc.edu.tw",
        "authorizedRedirectUris": [
          "https://sanshinechu.github.io"
        ]
      }
    }
  }
}
